# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=data_eng_kb

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
MAX_TOKENS=4096
TEMPERATURE=0.7

# Databricks (optional)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=

# Azure Data Factory (optional)
ADF_SUBSCRIPTION_ID=
ADF_RESOURCE_GROUP=
ADF_FACTORY_NAME=

# Dataverse (optional)
DATAVERSE_URL=
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=
DATAVERSE_TENANT_ID=

# Jira (optional)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
